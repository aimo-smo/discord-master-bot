# ═══════════════════════════════════════
#  انسخ هذا الملف إلى .env وعبّئ القيم
#  cp .env.example .env
# ═══════════════════════════════════════

# توكن البوت من Discord Developer Portal → Bot → Token
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# Application ID من OAuth2 → General
CLIENT_ID=

# معرف السيرفر (كليك يمين على السيرفر → Copy Server ID)
GUILD_ID=
